generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== 枚举 ====================

enum LeadSource {
  MANUAL_OUTREACH
  WEBSITE
  FACEBOOK
  TIKTOK
  WHATSAPP
  EMAIL
  REFERRAL
  EXHIBITION
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  REQUIREMENT_CONFIRMING
  QUOTING
  NEGOTIATING
  QUALIFIED
  WON
  LOST
  DORMANT
}

enum LeadTemperature {
  HOT
  WARM
  COLD
}

enum LeadGrade {
  A
  B
  C
  D
}

enum CustomerType {
  IMPORTER
  DISTRIBUTOR
  MANUFACTURER
  TRADER
  BRAND_OWNER
  RETAILER
  UNKNOWN
}

enum CustomerStatus {
  ACTIVE
  POTENTIAL
  INACTIVE
  WON
  LOST
  BLACKLIST
}

enum ProjectStatus {
  REQUIREMENT_CONFIRMING
  QUOTING
  SAMPLE_TESTING
  WAITING_FEEDBACK
  NEGOTIATING
  WON
  LOST
  PAUSED
}

enum FollowUpMethod {
  EMAIL
  WHATSAPP
  PHONE
  MEETING
  VIDEO_CALL
  OTHER
}

enum TaskType {
  FOLLOW_UP
  CALL
  MEETING
  QUOTE
  SAMPLE
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum QuoteStatus {
  DRAFT
  SENT
  WAITING_FEEDBACK
  REVISED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum Currency {
  USD
  EUR
  CNY
}

enum TemplateScene {
  FIRST_REPLY
  QUOTE_CONFIRMATION
  QUOTE_FOLLOW_UP
  SAMPLE_FOLLOW_UP
  NO_REPLY_FOLLOW_UP
  PRICE_NEGOTIATION
  ORDER_CONFIRMATION
  AFTER_SALES
  OTHER
}

enum TemplateLanguage {
  EN
  CN
  BOTH
}

enum AIAnalysisTargetType {
  LEAD
  CUSTOMER
  PROJECT
  FOLLOW_UP
  TEMPLATE
}

enum ExternalSourceType {
  WEBSITE_FORM
  FACEBOOK_FORM
  TIKTOK_MANUAL
  N8N
  AI_MARKETING_SYSTEM
  OPENCLAW
  WHATSAPP_MANUAL
  OTHER
}

enum WebhookStatus {
  SUCCESS
  FAILED
  UNAUTHORIZED
  DUPLICATE
  VALIDATION_ERROR
}

// ==================== 模型 ====================

model BusinessLine {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  code        String?   @unique
  description String?
  website     String?
  mainProducts String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  leads            Lead[]
  customers        Customer[]
  projects         Project[]
  products         Product[]
  templates        FollowUpTemplate[]
  externalSources  ExternalSource[]
}

model Lead {
  id              Int           @id @default(autoincrement())
  company         String
  contactName     String
  country         String?
  phone           String?
  email           String?
  whatsapp        String?
  source          LeadSource    @default(MANUAL_OUTREACH)
  sourceWebsite   String?
  status          LeadStatus    @default(NEW)
  temperature     LeadTemperature @default(WARM)
  grade           LeadGrade     @default(C)
  requirement     String?
  interestProducts String?
  inquiryContent  String?
  budget          Decimal?      @db.Decimal(12, 2)
  currency        Currency      @default(USD)
  expectedClosing DateTime?
  nextFollowUp    DateTime?
  remark          String?
  businessLineId  Int
  convertedCustomerId Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  businessLine       BusinessLine @relation(fields: [businessLineId], references: [id])
  convertedCustomer  Customer?    @relation("ConvertedLead", fields: [convertedCustomerId], references: [id])
  followUps          FollowUp[]
  quotes             Quote[]
  tasks              Task[]
  projects           Project[]

  @@index([businessLineId])
  @@index([status])
  @@index([temperature])
  @@index([grade])
  @@index([nextFollowUp])
}

model Customer {
  id             Int            @id @default(autoincrement())
  company        String
  contactName    String
  country        String?
  phone          String?
  email          String?
  whatsapp       String?
  website        String?
  address        String?
  industry       String?
  customerType   CustomerType   @default(UNKNOWN)
  customerStatus CustomerStatus @default(POTENTIAL)
  leadGrade      LeadGrade      @default(C)
  source         LeadSource?
  sourceWebsite  String?
  remark         String?
  businessLineId Int
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  businessLine  BusinessLine  @relation(fields: [businessLineId], references: [id])
  projects      Project[]
  followUps     FollowUp[]
  quotes        Quote[]
  tasks         Task[]
  convertedFrom Lead[]        @relation("ConvertedLead")

  @@index([businessLineId])
  @@index([customerStatus])
  @@index([customerType])
}

model Project {
  id                  Int           @id @default(autoincrement())
  name                String
  description         String?
  status              ProjectStatus @default(REQUIREMENT_CONFIRMING)
  productCategory     String?
  productName         String?
  specs               String?
  quantity            String?
  usage               String?
  targetMarket        String?
    specialRequirements String?
  amount              Decimal?      @db.Decimal(12, 2)
  currency            Currency      @default(USD)
  startDate           DateTime?
  endDate             DateTime?
  remark              String?
  businessLineId      Int
  customerId          Int
  leadId              Int?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  businessLine BusinessLine @relation(fields: [businessLineId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  lead         Lead?        @relation(fields: [leadId], references: [id])
  followUps    FollowUp[]
  quotes       Quote[]
  tasks        Task[]

  @@index([businessLineId])
  @@index([customerId])
  @@index([status])
}

model FollowUp {
  id              Int             @id @default(autoincrement())
  method          FollowUpMethod  @default(EMAIL)
  content         String
  customerFeedback String?
  nextAction      String?
  followUpDate    DateTime        @default(now())
  nextFollowUpDate DateTime?
  remark          String?
  leadId          Int?
  customerId      Int?
  projectId       Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  lead     Lead?     @relation(fields: [leadId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  project  Project?  @relation(fields: [projectId], references: [id])

  @@index([leadId])
  @@index([customerId])
  @@index([projectId])
  @@index([followUpDate])
  @@index([nextFollowUpDate])
}

model Quote {
  id            Int         @id @default(autoincrement())
  quoteNo       String      @unique
  productName   String?
  specs         String?
  quantity      String?
  unitPrice     Decimal?    @db.Decimal(12, 2)
  totalPrice    Decimal?    @db.Decimal(12, 2)
  currency      Currency    @default(USD)
  paymentTerms  String?
  deliveryTime  String?
  validUntil    DateTime?
  content       String?
  status        QuoteStatus @default(DRAFT)
  leadId        Int?
  customerId    Int?
  projectId     Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  lead     Lead?     @relation(fields: [leadId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  project  Project?  @relation(fields: [projectId], references: [id])

  @@index([leadId])
  @@index([customerId])
  @@index([projectId])
  @@index([status])
  @@index([quoteNo])
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  type        TaskType     @default(FOLLOW_UP)
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  leadId      Int?
  customerId  Int?
  projectId   Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lead     Lead?     @relation(fields: [leadId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  project  Project?  @relation(fields: [projectId], references: [id])

  @@index([leadId])
  @@index([customerId])
  @@index([projectId])
  @@index([status])
  @@index([dueDate])
}

model Product {
  id              Int          @id @default(autoincrement())
  name            String
  category        String?
  englishKeywords String?
  commonSpecs     String?
  application     String?
  targetMarket    String?
  notes           String?
  isActive        Boolean      @default(true)
  businessLineId  Int
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  businessLine BusinessLine @relation(fields: [businessLineId], references: [id])

  @@index([businessLineId])
  @@index([isActive])
}

model FollowUpTemplate {
  id              Int              @id @default(autoincrement())
  title           String
  scene           TemplateScene
  subject         String?
  content         String
  language        TemplateLanguage @default(EN)
  isActive        Boolean          @default(true)
  notes           String?
  businessLineId  Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  businessLine BusinessLine? @relation(fields: [businessLineId], references: [id])

  @@index([scene])
  @@index([language])
  @@index([isActive])
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  action      String
  entityType  String
  entityId    String?
  entityName  String?
  description String?
  createdAt   DateTime @default(now())

  @@index([entityType])
  @@index([createdAt])
}

model AIAnalysis {
  id                    Int                  @id @default(autoincrement())
  targetType            AIAnalysisTargetType
  targetId              Int
  title                 String?
  summary               String?
  requirementSummary    String?
  extractedRequirements String?
  qualificationLevel    String?
  intentLevel           String?
  buyerTypeGuess        String?
  riskPoints            String?
  missingInfo           String?
  suggestedQuestions    String?
  nextAction            String?
  whatsappReply         String?
  emailSubject          String?
  emailReply            String?
  internalSalesNote     String?
  rawInput              String?
  rawOutput             String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([targetType])
  @@index([targetId])
  @@index([createdAt])
  @@index([qualificationLevel])
  @@index([intentLevel])
}

model ExternalSource {
  id               Int                @id @default(autoincrement())
  name             String
  code             String             @unique
  sourceType       ExternalSourceType
  businessLineId   Int?
  defaultSource    LeadSource         @default(WEBSITE)
  defaultLeadGrade LeadGrade          @default(C)
  defaultPriority  TaskPriority       @default(MEDIUM)
  apiKeyHash       String?
  isActive         Boolean            @default(true)
  autoAnalyze      Boolean            @default(false)
  notes            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  businessLine BusinessLine? @relation(fields: [businessLineId], references: [id])
  webhookLogs  WebhookLog[]

  @@index([code])
  @@index([isActive])
}

model WebhookLog {
  id               Int           @id @default(autoincrement())
  externalSourceId  Int?
  externalSource   ExternalSource? @relation(fields: [externalSourceId], references: [id])
  sourceCode       String?
  status           WebhookStatus
  requestBody      String?
  responseBody     String?
  errorMessage     String?
  createdLeadId    Int?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime      @default(now())

  @@index([externalSourceId])
  @@index([status])
  @@index([createdAt])
}
