generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== 枚举 ====================

enum LeadSource {
  MANUAL_OUTREACH
  WEBSITE
  FACEBOOK
  TIKTOK
  WHATSAPP
  EMAIL
  REFERRAL
  EXHIBITION
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  REQUIREMENT_CONFIRMING
  QUOTING
  NEGOTIATING
  QUALIFIED
  WON
  LOST
  DORMANT
}

enum LeadTemperature {
  HOT
  WARM
  COLD
}

enum LeadGrade {
  A
  B
  C
  D
}

enum CustomerType {
  IMPORTER
  DISTRIBUTOR
  MANUFACTURER
  TRADER
  BRAND_OWNER
  RETAILER
  UNKNOWN
}

enum CustomerStatus {
  ACTIVE
  POTENTIAL
  INACTIVE
  WON
  LOST
  BLACKLIST
}

enum CustomerLifecycleStage {
  POTENTIAL
  INTENT
  FIRST_DEAL
  REPEAT_DEAL
  VIP
}

enum ProjectStatus {
  REQUIREMENT_CONFIRMING
  QUOTING
  SAMPLE_TESTING
  WAITING_FEEDBACK
  NEGOTIATING
  WON
  LOST
  PAUSED
}

enum FollowUpMethod {
  EMAIL
  WHATSAPP
  PHONE
  MEETING
  VIDEO_CALL
  OTHER
}

enum TaskType {
  FOLLOW_UP
  CALL
  MEETING
  QUOTE
  SAMPLE
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum QuoteStatus {
  DRAFT
  SENT
  WAITING_FEEDBACK
  REVISED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum Currency {
  USD
  EUR
  CNY
}

enum TemplateScene {
  FIRST_REPLY
  QUOTE_CONFIRMATION
  QUOTE_FOLLOW_UP
  SAMPLE_FOLLOW_UP
  NO_REPLY_FOLLOW_UP
  PRICE_NEGOTIATION
  ORDER_CONFIRMATION
  AFTER_SALES
  OTHER
}

enum TemplateLanguage {
  EN
  CN
  BOTH
}

enum AIAnalysisTargetType {
  LEAD
  CUSTOMER
  PROJECT
  FOLLOW_UP
  TEMPLATE
}

enum ExternalSourceType {
  WEBSITE_FORM
  FACEBOOK_FORM
  TIKTOK_MANUAL
  N8N
  AI_MARKETING_SYSTEM
  WHATSAPP_MANUAL
  OTHER
}

enum WebhookStatus {
  SUCCESS
  FAILED
  UNAUTHORIZED
  DUPLICATE
  VALIDATION_ERROR
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PRODUCTION
  READY_TO_SHIP
  SHIPPED
  COMPLETED
  CANCELLED
}

enum DocumentType {
  QUOTE
  CONTRACT
  ARTWORK
  SAMPLE_PHOTO
  PRODUCT_SPEC
  PACKING_REQUIREMENT
  OTHER
}

enum DocumentRelatedType {
  CUSTOMER
  PROJECT
  QUOTE
  ORDER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  TT
  LC
  PAYPAL
  WESTERN_UNION
  CASH
  OTHER
}

// ==================== 租户与用户 ====================

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  plan      String   @default("FREE") // FREE / PRO / ENTERPRISE
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  leads     Lead[]
  customers Customer[]
  quotes    Quote[]
  orders    Order[]
  tasks     Task[]

  @@index([isActive])
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("SALES") // ADMIN / MANAGER / SALES
  tenantId  Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([email])
}

// ==================== 模型 ====================

model BusinessLine {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  code        String?   @unique
  description String?
  website     String?
  mainProducts String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  leads            Lead[]
  customers        Customer[]
  projects         Project[]
  products         Product[]
  orders           Order[]
  templates        FollowUpTemplate[]
  externalSources  ExternalSource[]
}

model Lead {
  id              Int           @id @default(autoincrement())
  company         String
  contactName     String
  country         String?
  phone           String?
  email           String?
  whatsapp        String?
  source          LeadSource    @default(MANUAL_OUTREACH)
  sourceWebsite   String?
  status          LeadStatus    @default(NEW)
  temperature     LeadTemperature @default(WARM)
  grade           LeadGrade     @default(C)
  requirement     String?
  interestProducts String?
  inquiryContent  String?
  budget          Decimal?      @db.Decimal(12, 2)
  currency        Currency      @default(USD)
  expectedClosing DateTime?
  nextFollowUp    DateTime?
  remark          String?
  businessLineId  Int
  convertedCustomerId Int?
  ownerId         Int?
  ownerName       String?
  tenantId        Int?
  aiScore         Int?
  aiSummary       String?
  aiTags          String[]  @default([])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  businessLine       BusinessLine @relation(fields: [businessLineId], references: [id])
  convertedCustomer  Customer?    @relation("ConvertedLead", fields: [convertedCustomerId], references: [id])
  tenant             Tenant?    @relation(fields: [tenantId], references: [id])
  followUps          FollowUp[]
  quotes             Quote[]
  tasks              Task[]
  projects           Project[]
  emails             Email[]
  emailMessages      EmailMessage[]
  leadActivities    LeadActivity[]
  messages          Message[]

  @@index([businessLineId])
  @@index([status])
  @@index([temperature])
  @@index([grade])
  @@index([nextFollowUp])
  @@index([ownerId])
  @@index([tenantId])
}

model LeadActivity {
  id        Int      @id @default(autoincrement())
  leadId    Int
  type      String   @default("note") // call / email / whatsapp / note
  content   String
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdAt])
}

model Customer {
  id             Int            @id @default(autoincrement())
  company        String
  contactName    String
  country        String?
  phone          String?
  email          String?
  whatsapp       String?
  website        String?
  address        String?
  industry       String?
  customerType   CustomerType   @default(UNKNOWN)
  customerStatus CustomerStatus @default(POTENTIAL)
  lifecycleStage CustomerLifecycleStage @default(POTENTIAL)
  leadGrade      LeadGrade      @default(C)
  source         LeadSource?
  sourceWebsite  String?
  remark         String?
  aiScore        Int?
  aiIntentLevel  String?
  lastAiActionAt DateTime?
  ownerId         Int?
  ownerName       String?
  poolEnteredAt   DateTime?
  poolReason      String?
  businessLineId Int
  tenantId        Int?
  shortName       String?
  region          String?
  city            String?
  postalCode      String?
  companySize     String?
  rating          Int?
  tags            String[] @default([])
  stage           String   @default("NEW")
  purchaseIntent  String   @default("UNKNOWN")
  dealProbability Int?
  expectedDealValue Decimal? @db.Decimal(12, 2)
  expectedCloseDate DateTime?
  lastContactAt   DateTime?
  nextFollowUpAt  DateTime?
  lostReason      String?
  isArchived      Boolean  @default(false)
  archivedAt      DateTime?
  customCode      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  businessLine  BusinessLine  @relation(fields: [businessLineId], references: [id])
  tenant        Tenant?     @relation(fields: [tenantId], references: [id])
  contacts      Contact[]
  projects      Project[]
  followUps     FollowUp[]
  quotes        Quote[]
  tasks         Task[]
  orders        Order[]
  invoices      Invoice[]
  emails        Email[]
  emailMessages EmailMessage[]
  convertedFrom Lead[]        @relation("ConvertedLead")
  customerActivities CustomerActivity[]
  messages          Message[]

  @@index([ownerId])
  @@index([businessLineId])
  @@index([customerStatus])
  @@index([customerType])
  @@index([tenantId])
}

model Contact {
  id         Int      @id @default(autoincrement())
  customerId Int
  name       String
  position   String?
  email      String?
  whatsapp   String?
  phone      String?
  wechat     String?
  linkedin   String?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  orders   Order[]
  quotes   Quote[]
  emails   Email[]
  emailMessages EmailMessage[]
  messages     Message[]
  contactSocialProfiles ContactSocialProfile[]
  tenantId        Int?
  firstName       String?
  lastName        String?
  nickname        String?
  jobTitle        String?
  department      String?
  secondaryEmail  String?
  mobile          String?
  phoneCountryCode String?
  preferredContactMethod String?
  preferredLanguage String?
  timezone        String?

  @@index([customerId])
}

model CustomerActivity {
  id         Int      @id @default(autoincrement())
  customerId Int
  type       String   @default("note") // call / email / whatsapp / note
  content    String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([createdAt])
}

model Project {
  id                  Int           @id @default(autoincrement())
  name                String
  description         String?
  status              ProjectStatus @default(REQUIREMENT_CONFIRMING)
  productCategory     String?
  productName         String?
  specs               String?
  quantity            String?
  usage               String?
  targetMarket        String?
    specialRequirements String?
  amount              Decimal?      @db.Decimal(12, 2)
  currency            Currency      @default(USD)
  startDate           DateTime?
  endDate             DateTime?
  remark              String?
  businessLineId      Int
  customerId          Int
  leadId              Int?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  businessLine BusinessLine @relation(fields: [businessLineId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  lead         Lead?        @relation(fields: [leadId], references: [id])
  followUps    FollowUp[]
  quotes       Quote[]
  tasks        Task[]
  orders       Order[]

  @@index([businessLineId])
  @@index([customerId])
  @@index([status])
}

model FollowUp {
  id              Int             @id @default(autoincrement())
  method          FollowUpMethod  @default(EMAIL)
  content         String
  customerFeedback String?
  nextAction      String?
  followUpDate    DateTime        @default(now())
  nextFollowUpDate DateTime?
  remark          String?
  leadId          Int?
  customerId      Int?
  projectId       Int?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  lead     Lead?     @relation(fields: [leadId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  project  Project?  @relation(fields: [projectId], references: [id])

  @@index([leadId])
  @@index([customerId])
  @@index([projectId])
  @@index([followUpDate])
  @@index([nextFollowUpDate])
}

model Quote {
  id                 Int         @id @default(autoincrement())
  quoteNo            String      @unique
  quoteTitle         String?
  productName        String?
  specs              String?
  quantity           String?
  unitPrice          Decimal?    @db.Decimal(12, 2)
  totalPrice         Decimal?    @db.Decimal(12, 2)
  exchangeRate       Decimal?    @db.Decimal(12, 6)
  discountAmount     Decimal     @default(0) @db.Decimal(12, 2)
  currency           Currency    @default(USD)
  paymentTerms       String?
  deliveryTime       String?
  validDays          Int?
  deliveryTerm       String?
  shippingTerm       String?
  validUntil         DateTime?
  content            String?
  remarks            String?
  terms              String?
  status             QuoteStatus @default(DRAFT)
  leadId             Int?
  customerId         Int?
  projectId          Int?
  customerContactId  Int?
  tenantId           Int?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  lead            Lead?           @relation(fields: [leadId], references: [id])
  customer        Customer?       @relation(fields: [customerId], references: [id])
  project         Project?        @relation(fields: [projectId], references: [id])
  customerContact Contact?        @relation(fields: [customerContactId], references: [id])
  tenant          Tenant?       @relation(fields: [tenantId], references: [id])
  items           QuoteItem[]
  orders          Order[]
  tasks           Task[]
  emailMessages   EmailMessage[]
  messages        Message[]

  @@index([leadId])
  @@index([customerId])
  @@index([projectId])
  @@index([status])
  @@index([quoteNo])
  @@index([tenantId])
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  type        TaskType     @default(FOLLOW_UP)
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  leadId      Int?
  customerId  Int?
  projectId   Int?
  quoteId      Int?
  orderId      Int?
  ownerId      Int?
  ownerName    String?
  tenantId     Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lead     Lead?     @relation(fields: [leadId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  project  Project?  @relation(fields: [projectId], references: [id])
  quote Quote? @relation(fields: [quoteId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([leadId])
  @@index([customerId])
  @@index([projectId])
  @@index([status])
  @@index([dueDate])
  @@index([tenantId])
}

model Product {
  id              Int          @id @default(autoincrement())
  name            String
  category        String?
  englishKeywords String?
  commonSpecs     String?
  application     String?
  targetMarket    String?
  notes           String?
  isActive        Boolean      @default(true)
  businessLineId  Int
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  businessLine BusinessLine @relation(fields: [businessLineId], references: [id])
  quoteItems   QuoteItem[]
  orderItems   OrderItem[]

  @@index([businessLineId])
  @@index([isActive])
}

model FollowUpTemplate {
  id              Int              @id @default(autoincrement())
  title           String
  scene           TemplateScene
  subject         String?
  content         String
  language        TemplateLanguage @default(EN)
  isActive        Boolean          @default(true)
  notes           String?
  businessLineId  Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  businessLine BusinessLine? @relation(fields: [businessLineId], references: [id])

  @@index([scene])
  @@index([language])
  @@index([isActive])
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  action      String
  entityType  String
  entityId    String?
  entityName  String?
  description String?
  createdAt   DateTime @default(now())

  @@index([entityType])
  @@index([createdAt])
}

model CalendarEvent {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  eventType   String    @default("task") // task / meeting / holiday / reminder
  startTime   DateTime
  endTime     DateTime?
  allDay      Boolean   @default(false)
  isCompleted Boolean   @default(false)
  customerId  Int?
  leadId      Int?
  projectId   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startTime])
  @@index([eventType])
}

model SalesGoal {
  id           Int      @id @default(autoincrement())
  year         Int
  month        Int
  metricType   String   // leads_count / customers_count / orders_amount / quotes_count
  targetValue  Decimal  @db.Decimal(12, 2)
  currentValue Decimal  @default(0) @db.Decimal(12, 2)
  currency     Currency @default(USD)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([year, month, metricType])
}

model AIAnalysis {
  id                    Int                  @id @default(autoincrement())
  targetType            AIAnalysisTargetType
  targetId              Int
  title                 String?
  summary               String?
  requirementSummary    String?
  extractedRequirements String?
  qualificationLevel    String?
  intentLevel           String?
  buyerTypeGuess        String?
  riskPoints            String?
  missingInfo           String?
  suggestedQuestions    String?
  nextAction            String?
  whatsappReply         String?
  emailSubject          String?
  emailReply            String?
  internalSalesNote     String?
  rawInput              String?
  rawOutput             String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([targetType])
  @@index([targetId])
  @@index([createdAt])
  @@index([qualificationLevel])
  @@index([intentLevel])
}

model ExternalSource {
  id               Int                @id @default(autoincrement())
  name             String
  code             String             @unique
  sourceType       ExternalSourceType
  businessLineId   Int?
  defaultSource    LeadSource         @default(WEBSITE)
  defaultLeadGrade LeadGrade          @default(C)
  defaultPriority  TaskPriority       @default(MEDIUM)
  apiKeyHash       String?
  isActive         Boolean            @default(true)
  autoAnalyze      Boolean            @default(false)
  notes            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  businessLine BusinessLine? @relation(fields: [businessLineId], references: [id])
  webhookLogs  WebhookLog[]

  @@index([code])
  @@index([isActive])
}

model WebhookLog {
  id               Int           @id @default(autoincrement())
  externalSourceId  Int?
  externalSource   ExternalSource? @relation(fields: [externalSourceId], references: [id])
  sourceCode       String?
  status           WebhookStatus
  requestBody      String?
  responseBody     String?
  errorMessage     String?
  createdLeadId    Int?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime      @default(now())

  @@index([externalSourceId])
  @@index([status])
  @@index([createdAt])
}

model QuoteItem {
  id          Int      @id @default(autoincrement())
  quoteId     Int
  productId   Int?
  itemName    String
  specification String?
  quantity    Decimal? @db.Decimal(12, 2)
  unit        String?
  unitPrice   Decimal? @db.Decimal(12, 2)
  totalPrice  Decimal? @db.Decimal(12, 2)
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quote   Quote    @relation(fields: [quoteId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([quoteId])
}

model Order {
  id                    Int         @id @default(autoincrement())
  orderNo               String      @unique
  orderTitle            String?
  customerId            Int
  projectId             Int?
  quoteId               Int?
  contactId             Int?
  businessLineId        Int?
  orderStatus           OrderStatus @default(DRAFT)
  totalAmount           Decimal?    @db.Decimal(12, 2)
  exchangeRate          Decimal?    @db.Decimal(12, 6)
  currency              Currency    @default(USD)
  paymentTerm           String?
  deliveryTerm          String?
  expectedDeliveryDate  DateTime?
  tenantId              Int?
  notes                 String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  customer     Customer      @relation(fields: [customerId], references: [id])
  project      Project?      @relation(fields: [projectId], references: [id])
  quote        Quote?        @relation(fields: [quoteId], references: [id])
  contact      Contact?      @relation(fields: [contactId], references: [id])
  businessLine BusinessLine? @relation(fields: [businessLineId], references: [id])
  tenant       Tenant?     @relation(fields: [tenantId], references: [id])
  items        OrderItem[]
  invoices     Invoice[]
  tasks        Task[]
  emailMessages EmailMessage[]
  messages     Message[]

  @@index([customerId])
  @@index([projectId])
  @@index([quoteId])
  @@index([orderStatus])
  @@index([orderNo])
  @@index([businessLineId])
  @@index([tenantId])
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  productId   Int?
  itemName    String
  specification String?
  quantity    Decimal? @db.Decimal(12, 2)
  unit        String?
  unitPrice   Decimal? @db.Decimal(12, 2)
  totalPrice  Decimal? @db.Decimal(12, 2)
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order   Order    @relation(fields: [orderId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Document {
  id           Int                @id @default(autoincrement())
  title        String
  documentType DocumentType
  fileUrl      String?
  fileName     String?
  notes        String?
  relatedType  DocumentRelatedType
  relatedId    Int
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([relatedType, relatedId])
}

model Invoice {
  id          Int           @id @default(autoincrement())
  invoiceNo   String        @unique
  orderId     Int?
  customerId  Int
  amount      Decimal       @db.Decimal(12, 2)
  currency    Currency      @default(USD)
  status      InvoiceStatus @default(DRAFT)
  issuedAt    DateTime?
  dueDate     DateTime?
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order    Order?    @relation(fields: [orderId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  payments Payment[]

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([invoiceNo])
}

model Payment {
  id          Int           @id @default(autoincrement())
  invoiceId   Int
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod @default(TT)
  receivedAt  DateTime      @default(now())
  notes       String?
  createdAt   DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

// DEPRECATED: Use EmailAccount instead. Kept for backward compatibility.
model EmailConfig {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  host        String
  port        Int
  secure      Boolean  @default(true)
  username    String
  password    String
  fromName    String
  fromEmail   String
  imapHost    String?
  imapPort    Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// DEPRECATED: Use EmailMessage instead. Kept for backward compatibility.
model Email {
  id          Int      @id @default(autoincrement())
  direction   String   // in / out
  subject     String
  body        String
  bodyHtml    String?
  fromAddr    String
  toAddr      String
  ccAddr      String?
  messageId   String?  @unique
  inReplyTo   String?
  status      String   @default("sent") // sent / delivered / failed / read
  customerId  Int?
  contactId   Int?
  leadId      Int?
  sentAt      DateTime?
  receivedAt  DateTime?
  createdAt   DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  contact  Contact?  @relation(fields: [contactId], references: [id])
  lead     Lead?     @relation(fields: [leadId], references: [id])

  @@index([customerId])
  @@index([leadId])
  @@index([direction])
  @@index([createdAt])
}

model EmailAccount {
  id           Int      @id @default(autoincrement())
  name         String
  provider     String   @default("CUSTOM") // GMAIL / OUTLOOK / ALIYUN / NETEASE / CUSTOM
  emailAddress String
  imapHost     String?
  imapPort     Int?
  smtpHost     String?
  smtpPort     Int?
  smtpSecure   Boolean  @default(true)
  username     String
  password     String   // Will be encrypted in production
  oauthToken   String?  // For OAuth providers
  isActive     Boolean  @default(true)
  lastSyncAt   DateTime?
  tenantId     Int?
  userId       Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages  EmailMessage[]
  threads   EmailThread[]

  @@index([tenantId])
  @@index([userId])
  @@index([emailAddress])
}

model EmailMessage {
  id             Int      @id @default(autoincrement())
  accountId      Int
  threadId       Int?
  direction      String   // in / out
  messageId      String?  @unique  // RFC 2822 Message-ID
  inReplyTo      String?  // Parent message ID for threading
  fromAddr       String
  toAddr         String
  ccAddr         String?
  subject        String
  body           String
  bodyHtml       String?
  status         String   @default("received") // received / sent / draft / failed
  receivedAt     DateTime?
  sentAt         DateTime?
  isRead         Boolean  @default(false)
  isStarred      Boolean  @default(false)
  // CRM bindings
  leadId         Int?
  customerId     Int?
  contactId      Int?
  quoteId        Int?
  orderId        Int?
  tenantId       Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account  EmailAccount @relation(fields: [accountId], references: [id])
  thread   EmailThread? @relation(fields: [threadId], references: [id])
  lead     Lead?        @relation(fields: [leadId], references: [id])
  customer Customer?    @relation(fields: [customerId], references: [id])
  contact  Contact?     @relation(fields: [contactId], references: [id])
  quote    Quote?       @relation(fields: [quoteId], references: [id])
  order    Order?       @relation(fields: [orderId], references: [id])

  @@index([accountId])
  @@index([threadId])
  @@index([direction])
  @@index([leadId])
  @@index([customerId])
  @@index([contactId])
  @@index([isRead])
  @@index([createdAt])
}

model EmailThread {
  id           Int      @id @default(autoincrement())
  accountId    Int
  subject      String
  lastMessageAt DateTime?
  messageCount Int      @default(0)
  tenantId     Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account  EmailAccount  @relation(fields: [accountId], references: [id])
  messages EmailMessage[]

  @@index([accountId])
  @@index([lastMessageAt])
}

model AIConfig {
  id            Int      @id @default(autoincrement())
  provider      String   @default("OPENAI_COMPATIBLE")
  baseUrl       String
  apiKey        String
  model         String
  visionBaseUrl String?
  visionApiKey  String?
  visionModel   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model IMPlatform {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  appId       String?
  appSecret   String?
  encryptKey  String?
  verifyToken String?
  botToken    String?
  isActive    Boolean  @default(true)
  extra       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  imUsers    IMUser[]
  imMessages IMMessage[]
}

model IMUser {
  id             Int      @id @default(autoincrement())
  platformId     Int
  platformUserId String
  platformName   String?
  createdAt      DateTime @default(now())

  platform  IMPlatform  @relation(fields: [platformId], references: [id])
  messages  IMMessage[]

  @@unique([platformId, platformUserId])
  @@index([platformId])
}

model IMMessage {
  id           Int      @id @default(autoincrement())
  platformId   Int
  imUserId     Int
  direction    String
  content      String
  intent       String?
  action       String?
  actionResult Json?
  errorMsg     String?
  createdAt    DateTime @default(now())

  platform IMPlatform @relation(fields: [platformId], references: [id])
  imUser   IMUser     @relation(fields: [imUserId], references: [id])

  @@index([createdAt])
  @@index([platformId])
}

model ContactSocialProfile {
  id          Int      @id @default(autoincrement())
  tenantId    Int?
  contactId   Int
  platform    String
  account     String
  profileUrl  String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([tenantId])
}

model CustomFieldDefinition {
  id          Int      @id @default(autoincrement())
  tenantId    Int?
  entityType  String
  key         String
  label       String
  fieldType   String   @default("TEXT")
  description String?
  placeholder String?
  isRequired  Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  options     Json?
  defaultValue String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  values    CustomFieldValue[]

  @@unique([tenantId, entityType, key])
  @@index([tenantId, entityType])
}

model CustomFieldValue {
  id               Int      @id @default(autoincrement())
  tenantId         Int?
  fieldDefinitionId Int
  entityType       String
  entityId         Int
  value            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  fieldDefinition CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id])

  @@unique([fieldDefinitionId, entityType, entityId])
  @@index([entityType, entityId])
  @@index([tenantId])
}

model AILog {
  id         Int      @id @default(autoincrement())
  entityType String
  entityId   Int
  actionType String
  aiOutput   String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Message {
  id          Int      @id @default(autoincrement())
  channel     String   // email / whatsapp / webchat / manual
  direction   String   // inbound / outbound
  fromAddr    String
  toAddr      String?
  content     String
  contentType String   @default("text") // text / image / file
  // CRM bindings
  customerId  Int?
  leadId      Int?
  contactId   Int?
  quoteId     Int?
  orderId     Int?
  // AI analysis
  intent      String?  // inquiry / order / support / follow_up
  sentiment   String?  // positive / neutral / negative
  urgency     String?  // low / medium / high
  // Metadata
  externalId  String?  // Platform-specific message ID
  metadata    Json?
  tenantId    Int?
  createdAt   DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  lead     Lead?     @relation(fields: [leadId], references: [id])
  contact  Contact?  @relation(fields: [contactId], references: [id])
  quote    Quote?    @relation(fields: [quoteId], references: [id])
  order    Order?    @relation(fields: [orderId], references: [id])

  @@index([customerId])
  @@index([leadId])
  @@index([channel])
  @@index([direction])
  @@index([createdAt])
}

// ==================== AI Control System ====================

model AIControlSettings {
  id                  Int      @id @default(autoincrement())
  tenantId            Int?
  aiEnabled           Boolean  @default(true)
  salesAgentEnabled   Boolean  @default(true)
  emailAgentEnabled   Boolean  @default(true)
  whatsappAgentEnabled Boolean @default(false)
  followUpAgentEnabled Boolean @default(true)
  prospectingEnabled  Boolean  @default(false)
  executionMode       String   @default("MANUAL") // MANUAL / APPROVAL / AUTO
  workHoursStart      Int      @default(9)   // 9 AM
  workHoursEnd        Int      @default(18)  // 6 PM
  maxContactsPerDay   Int      @default(5)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([tenantId])
}

model AIPolicyRule {
  id          Int      @id @default(autoincrement())
  tenantId    Int?
  name        String
  type        String   @default("SOFT") // HARD / SOFT
  action      String   // block_send / limit_rate / block_blacklist / block_discount
  condition   String   // JSON condition
  value       String?  // threshold value
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// Used by AI Control System execution guard
model AIExecutionLog {
  id          Int      @id @default(autoincrement())
  tenantId    Int?
  actionType  String   // email_send / whatsapp_send / task_create / lead_analyze
  entityType  String?  // Lead / Customer / Quote / Order
  entityId    Int?
  allowed     Boolean
  reason      String?
  mode        String?  // MANUAL / APPROVAL / AUTO
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([actionType])
  @@index([allowed])
  @@index([createdAt])
}
